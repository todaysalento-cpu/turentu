{
  "name": "ride-system",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --verbose"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "car-query": "^1.0.12",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "fetch-cookie": "^3.2.0",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.6.2",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "mode": "^0.3.2",
    "multer": "^2.1.1",
    "ngeohash": "^0.6.3",
    "node-fetch": "^3.3.2",
    "node-geocoder": "^4.4.1",
    "nodemailer": "^8.0.1",
    "openai": "^6.27.0",
    "pg": "^8.18.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.7.0",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^20.3.1",
    "tough-cookie": "^6.0.0",
    "twilio": "^5.13.1",
    "undici": "^6.23.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "chalk": "^5.3.0",
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.7.0",
    "jest-spec-reporter": "^1.0.19",
    "nodemon": "^3.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "reporters": [
      "default",
      "jest-spec-reporter",
      [
        "jest-html-reporter",
        {
          "pageTitle": "Report Test TURENTU",
          "outputPath": "reports/test-report.html",
          "includeFailureMsg": true,
          "includeConsoleLog": true
        }
      ]
    ]
  }
}
